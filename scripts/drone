#!/usr/bin/env bash
# drone — one-word launcher for the Seagrass drone server.
#
# Loads SEAGRASS_TOKEN from ~/.seagrass-env, frees the Pixhawk serial port,
# starts server/drone_server.py, and prints "ready" only once the Pixhawk
# heartbeat is confirmed. See SETUP.md section 4.
set -euo pipefail

SCRIPT_PATH=$(readlink -f "$0")
REPO_DIR=$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)
ENV_FILE="${SEAGRASS_ENV_FILE:-$HOME/.seagrass-env}"

fail() { printf '\n❌ %s\n' "$*" >&2; exit 1; }

if [[ ! -f "$ENV_FILE" ]]; then
  (umask 077; cat > "$ENV_FILE" <<'EOF'
# Seagrass drone server secrets — sourced by the `drone` command and by
# drone-server.service (systemd). Keep this file out of git (mode 600).
# Paste the access token saved for this drone in the Fleet UI:
SEAGRASS_TOKEN=

# Optional overrides (defaults shown):
#PIXHAWK_PORT=/dev/ttyACM0
#PIXHAWK_BAUD=115200
#SEAGRASS_PORT=8765
EOF
  )
  fail "first run: created template $ENV_FILE
   One-time setup: edit it and paste the drone's access token from the Fleet UI
   into SEAGRASS_TOKEN=..., then run \`drone\` again."
fi

set -a
# shellcheck source=/dev/null
source "$ENV_FILE"
set +a

[[ -n "${SEAGRASS_TOKEN:-}" ]] || fail "SEAGRASS_TOKEN is empty in $ENV_FILE — paste the token from the Fleet UI."

PIXHAWK_PORT="${PIXHAWK_PORT:-/dev/ttyACM0}"
SEAGRASS_PORT="${SEAGRASS_PORT:-8765}"

# If the systemd service is running, Restart=always would respawn whatever we
# kill on the serial port — stop the unit before claiming it.
if command -v systemctl >/dev/null 2>&1 && systemctl is-active --quiet drone-server 2>/dev/null; then
  echo "Stopping drone-server.service (it would fight for $PIXHAWK_PORT)…"
  sudo systemctl stop drone-server
fi

# Kill anything still holding the Pixhawk serial port (stale drone_server.py,
# keyboard_control.py, sonar_logger.py, …). Nothing found is the happy path.
stale_pids=$(lsof -t "$PIXHAWK_PORT" 2>/dev/null || true)
if [[ -n "$stale_pids" ]]; then
  echo "Killing stale process(es) holding $PIXHAWK_PORT: $stale_pids"
  # shellcheck disable=SC2086  # intentional word splitting over PIDs
  kill -9 $stale_pids 2>/dev/null || true
  sleep 1
fi

LOG=$(mktemp -t drone-server-log.XXXXXX)
python3 -u "$REPO_DIR/server/drone_server.py" >"$LOG" 2>&1 &
SERVER_PID=$!
trap 'kill "$SERVER_PID" 2>/dev/null || true' INT TERM

echo "Starting drone server (log: $LOG)…"

# drone_server.py keeps running even when the Pixhawk connect fails, so gate
# "ready" on the heartbeat line, not just the websocket "listening" line.
for _ in $(seq 1 40); do  # ~20 s budget; the server's heartbeat timeout is 10 s
  if ! kill -0 "$SERVER_PID" 2>/dev/null; then
    cat "$LOG" >&2
    fail "drone server exited during startup — see output above."
  fi
  if grep -q "Pixhawk not available" "$LOG"; then
    grep "Pixhawk not available" "$LOG" >&2
    kill "$SERVER_PID" 2>/dev/null || true
    fail "no Pixhawk heartbeat — server stopped.
   Check: USB cable seated, Pixhawk powered, correct port ($PIXHAWK_PORT —
   override PIXHAWK_PORT in $ENV_FILE). Note: the safety switch does NOT block
   the heartbeat, only arming — a switch issue would not fail here."
  fi
  if grep -q "Pixhawk heartbeat OK" "$LOG" && grep -q "listening on ws://" "$LOG"; then
    cat "$LOG"
    echo "✅ ready — ws://$(hostname).local:$SEAGRASS_PORT (Ctrl-C to stop)"
    tail -f -n 0 "$LOG" &
    TAIL_PID=$!
    trap 'kill "$SERVER_PID" "$TAIL_PID" 2>/dev/null || true' INT TERM
    rc=0; wait "$SERVER_PID" || rc=$?
    kill "$TAIL_PID" 2>/dev/null || true
    exit "$rc"
  fi
  sleep 0.5
done

kill "$SERVER_PID" 2>/dev/null || true
cat "$LOG" >&2
fail "timed out waiting for Pixhawk heartbeat / server startup — see output above."
